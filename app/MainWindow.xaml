<Window x:Class="PcOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Optimizer" Height="820" Width="1340" MinWidth="1100" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        UseLayoutRounding="True" TextOptions.TextFormattingMode="Ideal">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="190" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{StaticResource BgPanelBrush}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="18,20,18,14">
          <TextBlock FontSize="17" FontWeight="SemiBold">
            <Run Text="PC " Foreground="{StaticResource TextPrimaryBrush}" /><Run Text="OPTIMIZER" Foreground="{StaticResource AccentBrush}" />
          </TextBlock>
          <TextBlock Style="{StaticResource Muted}" FontSize="11" Foreground="{StaticResource TextDimBrush}" Text="socio técnico de tu PC" Margin="0,2,0,0" />
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Padding="18,12">
          <StackPanel>
            <TextBlock x:Name="AdminBadge" Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" />
            <TextBlock Style="{StaticResource Muted}" FontSize="11" Foreground="{StaticResource TextDimBrush}" Text="v2.0.0 · modo experto" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <ListBox x:Name="Nav" Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource NavItem}"
                 SelectionChanged="Nav_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBoxItem Tag="dashboard">Dashboard</ListBoxItem>
          <ListBoxItem Tag="apps">Aplicaciones</ListBoxItem>
          <ListBoxItem Tag="startup">Arranque</ListBoxItem>
          <ListBoxItem Tag="cleanup">Limpieza</ListBoxItem>
          <ListBoxItem Tag="services">Servicios</ListBoxItem>
          <ListBoxItem Tag="privacy">Privacidad</ListBoxItem>
          <ListBoxItem Tag="performance">Rendimiento</ListBoxItem>
          <ListBoxItem Tag="health">Salud</ListBoxItem>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Contenido -->
    <Border Grid.Column="1" Background="{StaticResource BgDarkBrush}">
      <ContentControl x:Name="Host" />
    </Border>
  </Grid>
</Window>
