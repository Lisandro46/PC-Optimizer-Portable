<UserControl x:Class="PcOptimizer.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
  <UserControl.Resources>
    <x:Array x:Key="Actions" Type="sys:String">
      <sys:String>Desinstalar</sys:String>
      <sys:String>Desactivar</sys:String>
    </x:Array>
    <Style x:Key="RiskCell" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding RiskText}" Value="MEDIO">
          <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding RiskText}" Value="ALTO">
          <Setter Property="Foreground" Value="{StaticResource OrangeBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding RiskText}" Value="CRÍTICO">
          <Setter Property="Foreground" Value="{StaticResource RedBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="NumCell" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="24,20,24,18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0">
      <StackPanel>
        <TextBlock Style="{StaticResource H1}" Text="Aplicaciones y componentes" />
        <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0"
                   Text="Inventario completo. Nada se selecciona ni ejecuta solo. Consumo en vivo cada 10 s." />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <Button x:Name="MeasureButton" Style="{StaticResource GhostButton}" Content="Actualizar consumo" IsEnabled="False" Click="Measure_Click" Margin="0,0,8,0" />
        <Button x:Name="ScanButton" Style="{StaticResource GhostButton}" Content="Volver a escanear" Click="Scan_Click" />
      </StackPanel>
    </Grid>

    <!-- Filtros -->
    <Border Grid.Row="1" Background="#FF12161C" CornerRadius="8" Padding="12,10" Margin="0,16,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="330" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Height="34">
          <TextBox x:Name="SearchBox" TextChanged="Filter_Changed" VerticalContentAlignment="Center" />
          <TextBlock IsHitTestVisible="False" Text="Buscar por nombre, editor o ID…" VerticalAlignment="Center"
                     Margin="12,0,0,0" Foreground="{StaticResource TextDimBrush}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <ComboBox x:Name="SourceFilter" Grid.Column="1" Width="210" Margin="10,0,0,0" SelectionChanged="Filter_Changed" />
        <ComboBox x:Name="RiskFilter" Grid.Column="2" Width="150" Margin="10,0,0,0" SelectionChanged="Filter_Changed" />
        <Button x:Name="ClearButton" Grid.Column="4" Style="{StaticResource GhostButton}" Content="Desmarcar todo" Margin="10,0,10,0" Click="Clear_Click" />
        <TextBlock x:Name="SelectedCount" Grid.Column="5" VerticalAlignment="Center" Margin="4,0,4,0"
                   Foreground="{StaticResource AccentBrush}" Text="0 seleccionados" />
      </Grid>
    </Border>

    <!-- Grilla -->
    <Border Grid.Row="2" Background="#FF0E141B" CornerRadius="8">
      <DataGrid x:Name="AppGrid" Margin="2" CanUserSortColumns="True"
                CellEditEnding="Grid_CellEditEnding">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="38" CanUserSort="False">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Center" Click="RowCheck_Click" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Aplicación o componente" Binding="{Binding Name}" Width="*" MinWidth="200" IsReadOnly="True" />
          <DataGridTextColumn Header="Origen" Binding="{Binding Source}" Width="150" IsReadOnly="True">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" /></Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Editor" Binding="{Binding Publisher}" Width="150" IsReadOnly="True">
            <DataGridTextColumn.ElementStyle>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
              </Style>
            </DataGridTextColumn.ElementStyle>
          </DataGridTextColumn>
          <DataGridTextColumn Header="Estado" Binding="{Binding State}" Width="84" IsReadOnly="True" />

          <DataGridTemplateColumn Header="Riesgo" Width="78" SortMemberPath="Risk">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding RiskText}" Style="{StaticResource RiskCell}" VerticalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="CPU" Binding="{Binding CpuText}" Width="78" IsReadOnly="True"
                              SortMemberPath="CpuPercent" ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="RAM" Binding="{Binding MemoryText}" Width="80" IsReadOnly="True"
                              SortMemberPath="MemoryMb" ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="Disco" Binding="{Binding DiskText}" Width="92" IsReadOnly="True"
                              SortMemberPath="DiskMbPerSecond" ElementStyle="{StaticResource NumCell}" />
          <DataGridTextColumn Header="Proc." Binding="{Binding ProcessText}" Width="62" IsReadOnly="True"
                              SortMemberPath="ProcessCount" ElementStyle="{StaticResource NumCell}" />

          <DataGridTemplateColumn Header="Acción" Width="120" CanUserSort="False">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <ComboBox ItemsSource="{StaticResource Actions}" Margin="2"
                          SelectedItem="{Binding Action, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTemplateColumn Header="Info" Width="52" CanUserSort="False">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="?" Style="{StaticResource GhostButton}" Padding="0" Width="30" Height="24"
                        FontWeight="SemiBold" Click="Info_Click" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Footer -->
    <Grid Grid.Row="3" Margin="0,14,0,0">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <ProgressBar x:Name="Progress" Width="200" Height="6" IsIndeterminate="True" Visibility="Collapsed"
                     Foreground="{StaticResource AccentBrush}" Background="#FF1B2430" BorderThickness="0" />
        <TextBlock x:Name="Status" Margin="14,0,0,0" VerticalAlignment="Center" MaxWidth="640"
                   TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextMutedBrush}" Text="Esperando escaneo..." />
      </StackPanel>
      <Button x:Name="PlanButton" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
              Content="REVISAR PLAN" IsEnabled="False" Click="Plan_Click" />
    </Grid>
  </Grid>
</UserControl>
