<UserControl x:Class="PcOptimizer.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="32">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
      <TextBlock x:Name="TitleText" Style="{StaticResource H1}" HorizontalAlignment="Center" />
      <TextBlock x:Name="SubText" Style="{StaticResource Muted}" FontSize="14" TextAlignment="Center"
                 TextWrapping="Wrap" Margin="0,12,0,0" />
      <Border Style="{StaticResource Card}" Margin="0,24,0,0" HorizontalAlignment="Center" Padding="14,10">
        <TextBlock Foreground="{StaticResource CyanBrush}" FontSize="12.5" Text="En construcción — próximo módulo" />
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
