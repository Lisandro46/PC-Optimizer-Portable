<Window x:Class="PcOptimizer.PlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plan antes de ejecutar" Height="680" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}">
  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Style="{StaticResource H1}" Foreground="{StaticResource AccentBrush}" Text="Revisá el plan completo" />
    <TextBlock Grid.Row="1" x:Name="Summary" Style="{StaticResource Muted}" FontSize="13" Margin="0,8,0,0" />

    <Border Grid.Row="2" Margin="0,14,0,0" Background="#FF161A20" CornerRadius="8">
      <TextBox x:Name="Details" IsReadOnly="True" Background="Transparent" BorderThickness="0"
               FontFamily="Consolas" FontSize="12.5" Padding="14"
               VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
    </Border>

    <CheckBox Grid.Row="3" x:Name="Restore" IsChecked="True" Margin="0,14,0,0" Foreground="{StaticResource TextPrimaryBrush}"
              Content="Intentar crear un punto de restauración antes de cambiar nada" />

    <Grid Grid.Row="4" Margin="0,16,0,0">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                   Text="Para habilitar la ejecución escribí:" />
        <TextBlock VerticalAlignment="Center" Margin="6,0,10,0" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}" Text="EJECUTAR" />
        <TextBox x:Name="Confirm" Width="180" TextChanged="Confirm_Changed" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="CancelButton" Style="{StaticResource GhostButton}" Content="Cancelar" Width="120" Click="Cancel_Click" Margin="0,0,10,0" />
        <Button x:Name="ExecuteButton" Style="{StaticResource PrimaryButton}" Content="Ejecutar plan" IsEnabled="False" Click="Execute_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
